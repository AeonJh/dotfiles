  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{ tmp=$(mktemp /tmp/cliproxy-quota.XXXXXX) && if bash \"{{ .chezmoi.homeDir }}/.claude/bin/codex-quota.sh\" > \"$tmp\"; then mv \"$tmp\" \"/tmp/cliproxy-quota.json\"; else rm -f \"$tmp\"; fi; } 2>/dev/null || true",
