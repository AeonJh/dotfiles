#!/usr/bin/env bash

set -euo pipefail

# Trigger: rerun this script when rendered tmux.conf changes.
# {{ include "dot_config/tmux/tmux.conf" | sha256sum }}

TMUX_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf"

if ! command -v tmux >/dev/null 2>&1; then
  echo "[chezmoi] tmux not found, skip tmux reload"
  exit 0
fi

if [[ ! -f "$TMUX_CONF" ]]; then
  echo "[chezmoi] $TMUX_CONF not found, skip tmux reload"
  exit 0
fi

if tmux list-sessions >/dev/null 2>&1; then
  tmux source-file "$TMUX_CONF"
  tmux display-message "chezmoi: reloaded $TMUX_CONF" 2>/dev/null || true
  echo "[chezmoi] reloaded $TMUX_CONF"
else
  echo "[chezmoi] tmux is installed, but no tmux server is running; config will be read on next tmux start"
fi
